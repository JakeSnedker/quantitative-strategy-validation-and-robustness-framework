# JJC Bot Optimizer Configuration
# Copy this file to .env and fill in your values

# ============================================
# MT5 Configuration
# ============================================

# Path to your MT5 terminal folder (containing terminal64.exe)
# Find this in MT5: File -> Open Data Folder, then go up one level
# Example: C:\Program Files\MetaTrader 5
MT5_TERMINAL_PATH=C:\Users\YourName\AppData\Roaming\MetaQuotes\Terminal\YOUR_TERMINAL_ID

# Path to MT5 data folder (where experts, sets, etc. are stored)
# Usually: C:\Users\YourName\AppData\Roaming\MetaQuotes\Terminal\YOUR_TERMINAL_ID\MQL5
MT5_DATA_PATH=C:\Users\YourName\AppData\Roaming\MetaQuotes\Terminal\YOUR_TERMINAL_ID\MQL5

# EA filename (without path)
EA_NAME=JJC_Bot-V13.3  (OTN Added).ex5

# ============================================
# Backtest Configuration
# ============================================

# Default symbol for testing
DEFAULT_SYMBOL=US30

# Default timeframe (M1, M5, M15, H1, etc.)
DEFAULT_TIMEFRAME=M1

# Default test period (format: YYYY.MM.DD)
DEFAULT_START_DATE=2025.08.01
DEFAULT_END_DATE=2026.02.01

# Modeling mode: 0=Every tick, 1=1 minute OHLC, 2=Open price only
MODELING_MODE=1

# Initial deposit for testing
INITIAL_DEPOSIT=10000

# ============================================
# LLM Configuration
# ============================================

# LLM Provider: anthropic, openai, ollama
LLM_PROVIDER=anthropic

# API Keys (leave blank if using ollama)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Ollama settings (if using local model)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2

# Model selection
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-4-turbo

# ============================================
# Optimization Settings
# ============================================

# Maximum optimization iterations before stopping
MAX_ITERATIONS=50

# Stop if profit factor exceeds this value
TARGET_PROFIT_FACTOR=1.5

# Stop if max drawdown is below this percentage
TARGET_MAX_DRAWDOWN=5.0

# Minimum improvement rate (stop if improvement stalls)
MIN_IMPROVEMENT_RATE=0.01

# Seconds to wait for MT5 backtest to complete
BACKTEST_TIMEOUT=600

# ============================================
# Output Settings
# ============================================

# Where to save optimization results
RESULTS_PATH=./optimization_results

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
